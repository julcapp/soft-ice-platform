generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  CREATED
  PAYMENT_PENDING
  PAID
  DISPENSING
  COMPLETED
  FAILED
  CANCELLED
}

enum MachineStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ERROR
}

enum DispenseRequestState {
  REQUESTED
  STARTED
  COMPLETED
  FAILED
}

model Customer {
  id                String   @id @default(uuid())
  phone             String?  @unique
  phoneVerifiedAt   DateTime?
  primaryIdentityProvider String?
  name              String?
  telegramId        String?  @unique
  telegramUsername  String?
  email             String?
  birthday          DateTime?
  vkProfile         String?
  status            String   @default("active")
  trustedStatus     Boolean  @default(false)
  trustedStatusAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clubAccount       ClubAccount?
  identities        CustomerIdentity[]
  authSessions      AuthSession[]
  bonusAccount      BonusAccount?
  orders            Order[]
  consents          CustomerConsent[]
  bonusTransactions BonusTransaction[]
  referralsMade     Referral[] @relation("Referrer")
  referredBy        Referral[] @relation("Referred")
  photoChallenges   PhotoChallenge[]
  birthdayRewards   BirthdayReward[]
  payments          Payment[]
  segmentAssignments CustomerSegment[]
}

enum OperatorRole {
  OPERATOR
  ADMIN
}

enum OperatorStatus {
  ACTIVE
  SUSPENDED
}

enum MaintenanceTaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ServiceLogStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum TestRunStatus {
  PASSED
  FAILED
}

enum InventoryMovementType {
  CONSUMPTION
  REPLENISHMENT
  ADJUSTMENT
}

enum InventoryItemType {
  CUP
  ICE_CREAM_MIX
  TOPPING
}

enum SegmentType {
  MANUAL
  SYSTEM
}

enum SegmentStatus {
  ACTIVE
  INACTIVE
}

model Segment {
  id          String        @id @default(uuid())
  code        String        @unique
  name        String
  description String?
  type        SegmentType
  status      SegmentStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  rules       SegmentRule[]
  assignments CustomerSegment[]

  @@index([status, type])
}

model SegmentRule {
  id        String   @id @default(uuid())
  segmentId String
  ruleType  String
  criteria  Json
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segment   Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([segmentId, priority])
}

model CustomerSegment {
  id           String    @id @default(uuid())
  customerId   String
  segmentId    String
  source       String
  reason       String?
  assignedBy   String?
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  customer     Customer  @relation(fields: [customerId], references: [id])
  segment      Segment   @relation(fields: [segmentId], references: [id])

  @@index([customerId, unassignedAt, assignedAt])
  @@index([segmentId, unassignedAt, assignedAt])
}

model CustomerIdentity {
  id                  String   @id @default(uuid())
  customerId          String
  provider            String
  externalSubjectHash String
  externalUsername    String?
  displayName         String?
  verificationMethod  String
  status              String   @default("active")
  sourceChannel       String?
  verifiedAt          DateTime @default(now())
  linkedAt            DateTime @default(now())
  lastSeenAt          DateTime @default(now())
  revokedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            Customer @relation(fields: [customerId], references: [id])

  @@unique([provider, externalSubjectHash])
}

model AuthSession {
  id              String   @id @default(uuid())
  subjectType     String
  customerId      String
  authMethod      String
  consumerType    String
  accessTokenHash String   @unique
  tokenType       String   @default("Bearer")
  correlationId   String?
  createdAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?

  customer        Customer @relation(fields: [customerId], references: [id])
}

model IdempotencyRecord {
  id              String   @id @default(uuid())
  scope           String
  key             String
  actorContext    Json?
  semanticHash    String
  status          String
  resultReference String?
  correlationId   String?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  expiresAt       DateTime?

  @@unique([scope, key])
}

model AuditEvent {
  id            String   @id @default(uuid())
  eventType     String
  subjectType   String?
  subjectId     String?
  targetType    String?
  targetId      String?
  action        String
  decision      String
  reasonCode    String?
  authMethod    String?
  sourceChannel String?
  correlationId String?
  metadata      Json?
  occurredAt    DateTime @default(now())
}

model DocumentVersion {
  id            String   @id @default(uuid())
  documentType  String
  version       String
  title         String
  filePath      String
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  consents      CustomerConsent[]

  @@unique([documentType, version])
}

enum ConsentType {
  PERSONAL_DATA
  MARKETING
  ADVERTISING
  PARTNER_OFFERS
  PHOTO_USAGE
}

enum ConsentSourceChannel {
  TELEGRAM
  MINI_APP
  MACHINE
  WEBSITE
}

model CustomerConsent {
  id             String   @id @default(uuid())
  customerId     String
  documentId     String
  consentType    ConsentType
  isGranted      Boolean  @default(true)
  consentedAt    DateTime @default(now())
  revokedAt      DateTime?
  sourceChannel  ConsentSourceChannel
  ipAddress      String?
  decisionId     String
  correlationId  String?

  customer       Customer @relation(fields: [customerId], references: [id])
  document       DocumentVersion @relation(fields: [documentId], references: [id])

  @@index([customerId, consentType, consentedAt])
  @@unique([customerId, decisionId])
}

model ClubAccount {
  id                 String   @id @default(uuid())
  customerId         String   @unique
  status             String   @default("active")
  currency           String   @default("RUB")
  balanceRub         Float    @default(0)
  availableBalanceRub Float   @default(0)
  reservedBalanceRub Float    @default(0)
  clubActive         Boolean  @default(false)
  activatedAt        DateTime?
  lastTopupAt        DateTime?
  lastTransactionId  String?
  projectionVersion  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer           Customer @relation(fields: [customerId], references: [id])
  topups             ClubTopup[]
  transactions       ClubAccountTransaction[]
}

model ClubAccountTransaction {
  id                       String   @id @default(uuid())
  clubAccountId            String
  customerId               String
  transactionType          String
  direction                String
  amountRub                Float
  currency                 String   @default("RUB")
  availableDeltaRub        Float
  reservedDeltaRub         Float    @default(0)
  availableBalanceAfterRub Float
  reservedBalanceAfterRub  Float
  balanceAfterRub          Float
  status                   String   @default("posted")
  reason                   String
  referenceEntityType      String?
  referenceEntityId        String?
  sourceDomain             String?
  sourceId                 String?
  idempotencyKey           String?
  actorType                String   @default("customer")
  actorId                  String?
  correlationId            String?
  createdAt                DateTime @default(now())
  postedAt                 DateTime @default(now())

  clubAccount              ClubAccount @relation(fields: [clubAccountId], references: [id])

  @@unique([clubAccountId, idempotencyKey])
  @@index([customerId, postedAt])
  @@index([clubAccountId, postedAt])
}

model ClubTopup {
  id              String   @id @default(uuid())
  clubAccountId   String
  customerId      String
  amountRub       Float
  paymentProvider String
  paymentStatus   String   @default("pending")
  paymentId       String?
  channel         String
  createdAt       DateTime @default(now())
  paidAt          DateTime?

  clubAccount     ClubAccount @relation(fields: [clubAccountId], references: [id])
  payment         Payment?
}

model BonusAccount {
  id             String   @id @default(uuid())
  customerId     String   @unique
  balanceBonus   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer       Customer @relation(fields: [customerId], references: [id])
}

model BonusTransaction {
  id             String   @id @default(uuid())
  customerId     String
  orderId        String?
  referralId     String?
  type           String
  direction      String   @default("credit")
  amountBonus    Int
  source         String
  reason         String?
  referenceEntityType String?
  referenceEntityId   String?
  balanceAfterBonus   Int?
  comment        String?
  createdAt      DateTime @default(now())
  postedAt       DateTime @default(now())

  customer       Customer @relation(fields: [customerId], references: [id])
  order          Order?   @relation(fields: [orderId], references: [id])
  referral       Referral? @relation(fields: [referralId], references: [id])
}

model Machine {
  id               String        @id @default(uuid())
  machineCode      String        @unique
  name             String
  location         String?
  status           MachineStatus @default(OFFLINE)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  orders           Order[]
  inventory        MachineInventory[]
  dispenseRequests DispenseRequest[]
  maintenanceTasks MaintenanceTask[]
  serviceLogs      ServiceLog[]
  testRuns         TestRun[]
  inventoryMovements InventoryMovement[]
  settings         MachineSetting[]
}

model MachineInventory {
  id             String   @id @default(uuid())
  machineId      String
  itemType       String
  itemName       String
  capacity       Int?
  quantityLeft   Int?
  updatedAt      DateTime @updatedAt

  machine        Machine @relation(fields: [machineId], references: [id])
}

model Operator {
  id              String         @id @default(uuid())
  displayName     String
  externalSubject String?        @unique
  role            OperatorRole   @default(OPERATOR)
  status          OperatorStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  permissions      OperatorPermission[]
  maintenanceTasks MaintenanceTask[] @relation("MaintenanceTaskAssignee")
  completedTasks   MaintenanceTask[] @relation("MaintenanceTaskCompleter")
  serviceLogs      ServiceLog[]
  approvedServiceLogs ServiceLog[] @relation("ServiceLogApprover")
  testRuns         TestRun[]
  inventoryMovements InventoryMovement[]
  photoEvidence    PhotoEvidence[]
  checklistVersions MaintenanceChecklist[]
  machineSettings  MachineSetting[]
}

model OperatorPermission {
  id         String   @id @default(uuid())
  operatorId String
  permission String
  grantedAt  DateTime @default(now())
  grantedBy  String?

  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@unique([operatorId, permission])
  @@index([permission])
}

model MaintenanceChecklist {
  id          String   @id @default(uuid())
  code        String
  name        String
  version     Int
  items       Json
  active      Boolean  @default(true)
  configuredById String
  createdAt   DateTime @default(now())

  configuredBy Operator @relation(fields: [configuredById], references: [id])
  tasks        MaintenanceTask[]

  @@unique([code, version])
  @@index([code, active])
}

model MaintenanceTask {
  id            String                @id @default(uuid())
  machineId     String
  checklistId   String
  assignedToId  String
  completedById String?
  status        MaintenanceTaskStatus @default(OPEN)
  checklistResults Json?
  notes         String?
  dueAt         DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  machine       Machine @relation(fields: [machineId], references: [id])
  checklist     MaintenanceChecklist @relation(fields: [checklistId], references: [id])
  assignedTo    Operator @relation("MaintenanceTaskAssignee", fields: [assignedToId], references: [id])
  completedBy   Operator? @relation("MaintenanceTaskCompleter", fields: [completedById], references: [id])
  serviceLogs   ServiceLog[]
  photoEvidence PhotoEvidence[]

  @@index([assignedToId, status, dueAt])
  @@index([machineId, status])
}

model ServiceLog {
  id                String           @id @default(uuid())
  machineId         String
  maintenanceTaskId String?
  operatorId        String
  status            ServiceLogStatus @default(DRAFT)
  summary           String
  workPerformed     Json
  submittedAt       DateTime?
  approvedById      String?
  approvedAt        DateTime?
  approvalNote      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  machine           Machine @relation(fields: [machineId], references: [id])
  maintenanceTask   MaintenanceTask? @relation(fields: [maintenanceTaskId], references: [id])
  operator          Operator @relation(fields: [operatorId], references: [id])
  approvedBy        Operator? @relation("ServiceLogApprover", fields: [approvedById], references: [id])
  photoEvidence     PhotoEvidence[]

  @@index([machineId, createdAt])
  @@index([status, submittedAt])
}

model TestRun {
  id          String        @id @default(uuid())
  machineId   String
  operatorId  String
  status      TestRunStatus
  notes       String?
  results     Json?
  performedAt DateTime      @default(now())

  machine     Machine @relation(fields: [machineId], references: [id])
  operator    Operator @relation(fields: [operatorId], references: [id])
  inventoryMovements InventoryMovement[]
  photoEvidence PhotoEvidence[]

  @@index([machineId, performedAt])
  @@index([operatorId, performedAt])
}

model InventoryMovement {
  id          String                @id @default(uuid())
  machineId   String
  operatorId  String
  testRunId   String?
  movementType InventoryMovementType
  itemType    InventoryItemType
  itemReference String?
  quantity    Float
  unit        String
  reason      String
  idempotencyKey String?
  occurredAt  DateTime              @default(now())

  machine     Machine @relation(fields: [machineId], references: [id])
  operator    Operator @relation(fields: [operatorId], references: [id])
  testRun     TestRun? @relation(fields: [testRunId], references: [id])

  @@unique([machineId, idempotencyKey])
  @@index([machineId, occurredAt])
  @@index([testRunId])
}

model PhotoEvidence {
  id                String   @id @default(uuid())
  operatorId        String
  maintenanceTaskId String?
  serviceLogId      String?
  testRunId         String?
  storageKey        String   @unique
  contentType       String
  checksumSha256    String
  capturedAt        DateTime
  uploadedAt        DateTime @default(now())
  metadata          Json?

  operator          Operator @relation(fields: [operatorId], references: [id])
  maintenanceTask   MaintenanceTask? @relation(fields: [maintenanceTaskId], references: [id])
  serviceLog        ServiceLog? @relation(fields: [serviceLogId], references: [id])
  testRun           TestRun? @relation(fields: [testRunId], references: [id])

  @@index([maintenanceTaskId])
  @@index([serviceLogId])
  @@index([testRunId])
}

model MachineSetting {
  id          String   @id @default(uuid())
  machineId   String
  key         String
  value       Json
  updatedById String
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  machine     Machine @relation(fields: [machineId], references: [id])
  updatedBy   Operator @relation(fields: [updatedById], references: [id])

  @@unique([machineId, key])
}

model Order {
  id                  String      @id @default(uuid())
  customerId           String
  status              OrderStatus @default(CREATED)
  amount              Float
  currency            String      @default("RUB")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  machineId            String?
  flavor               String?
  syrup                String?
  topping              String?
  basePriceRub         Float?
  clubDiscountRub      Float      @default(0)
  promoDiscountRub     Float      @default(0)
  bonusSpent           Int        @default(0)
  amountPaidRub        Float?
  bonusEarned          Int        @default(0)
  paymentMethod        String?
  paymentStatus        String     @default("pending")
  paidAt               DateTime?

  customer             Customer @relation(fields: [customerId], references: [id])
  machine              Machine? @relation(fields: [machineId], references: [id])
  dispenseRequest      DispenseRequest?
  bonusTransactions    BonusTransaction[]
  photoChallenge       PhotoChallenge?
  birthdayReward       BirthdayReward?

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model DispenseRequest {
  id              String               @id @default(uuid())
  orderId         String               @unique
  machineId       String
  state           DispenseRequestState @default(REQUESTED)
  commandId       String               @unique
  commandType     String               @default("DispenseCommand")
  commandPayload  Json
  failureReason   String?
  requestedAt     DateTime             @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  order           Order                @relation(fields: [orderId], references: [id])
  machine         Machine              @relation(fields: [machineId], references: [id])

  @@index([machineId, state])
  @@index([state, createdAt])
}

model Referral {
  id                    String   @id @default(uuid())
  referrerCustomerId     String
  referredCustomerId     String?  @unique
  referralCode           String
  status                 String   @default("registered")
  firstPurchaseAt        DateTime?
  referrerBonusPaid      Boolean  @default(false)
  referredBonusPaid      Boolean  @default(false)
  milestoneBonusPaid     Boolean  @default(false)
  createdAt              DateTime @default(now())

  referrer               Customer @relation("Referrer", fields: [referrerCustomerId], references: [id])
  referred               Customer? @relation("Referred", fields: [referredCustomerId], references: [id])
  bonusTransactions      BonusTransaction[]
}

model PhotoChallenge {
  id             String   @id @default(uuid())
  customerId     String
  orderId        String   @unique
  photoFilePath  String?
  platform       String?
  postUrl        String?
  deadlineAt     DateTime
  status         String   @default("waiting")
  moderatorId    String?
  bonusAmount    Int      @default(30)
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())

  customer       Customer @relation(fields: [customerId], references: [id])
  order          Order    @relation(fields: [orderId], references: [id])
}

model BirthdayReward {
  id             String   @id @default(uuid())
  customerId     String
  year           Int
  status         String   @default("available")
  issuedAt       DateTime @default(now())
  expiresAt      DateTime
  redeemedAt     DateTime?
  orderId        String?  @unique

  customer       Customer @relation(fields: [customerId], references: [id])
  order          Order? @relation(fields: [orderId], references: [id])

  @@unique([customerId, year])
}

model Payment {
  id                String   @id @default(uuid())
  customerId        String?
  clubTopupId       String?  @unique

  amountRub         Float
  currency          String   @default("RUB")

  provider          String   @default("yookassa")
  providerPaymentId String?  @unique
  providerStatus    String?

  status            String   @default("pending")
  description       String?

  confirmationUrl   String?
  returnUrl         String?

  metadata          Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  confirmedAt       DateTime?
  canceledAt        DateTime?

  customer          Customer? @relation(fields: [customerId], references: [id])
  clubTopup         ClubTopup? @relation(fields: [clubTopupId], references: [id])
}
