NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# PostgreSQL is the MVP backend database.
# This value matches backend/docker-compose.yml defaults.
DATABASE_URL=postgresql://soft_ice_platform:soft_ice_platform@localhost:5432/soft_ice_platform?schema=public
DATABASE_SSL=false
DATABASE_CONNECTION_LIMIT=5

# Telegram Mini App authentication.
# Use a real bot token only in a secure runtime environment, never in source control.
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Platform infrastructure. Secrets are supplied by the deployment environment.
LOG_LEVEL=debug
SHUTDOWN_TIMEOUT_MS=10000
FEATURE_PAYMENTS_ENABLED=false
FEATURE_MACHINE_DISPATCH_ENABLED=false

# Local Docker Compose PostgreSQL settings.
POSTGRES_DB=soft_ice_platform
POSTGRES_USER=soft_ice_platform
POSTGRES_PASSWORD=soft_ice_platform
POSTGRES_PORT=5432
HUAXIN_MACHINE_ID=huaxin_default
HUAXIN_HEARTBEAT_INTERVAL_MS=15000
HUAXIN_HEARTBEAT_TIMEOUT_MS=45000
HUAXIN_COMMAND_TIMEOUT_MS=5000
HUAXIN_RECONNECT_BASE_DELAY_MS=1000
HUAXIN_RECONNECT_MAX_DELAY_MS=30000
HUAXIN_MAX_RECONNECT_ATTEMPTS=5
HUAXIN_COMMAND_QUEUE_SIZE=100
HUAXIN_TELEMETRY_LIMIT=100
