generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  CREATED
  PAYMENT_PENDING
  PAID
  DISPENSING
  COMPLETED
  FAILED
  CANCELLED
}

model Customer {
  id                String   @id @default(uuid())
  phone             String?  @unique
  name              String?
  telegramId        String?  @unique
  telegramUsername  String?
  email             String?
  birthday          DateTime?
  vkProfile         String?
  status            String   @default("active")
  trustedStatus     Boolean  @default(false)
  trustedStatusAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clubAccount       ClubAccount?
  identities        CustomerIdentity[]
  authSessions      AuthSession[]
  bonusAccount      BonusAccount?
  orders            Order[]
  consents          CustomerConsent[]
  bonusTransactions BonusTransaction[]
  referralsMade     Referral[] @relation("Referrer")
  referredBy        Referral[] @relation("Referred")
  photoChallenges   PhotoChallenge[]
  birthdayRewards   BirthdayReward[]
  payments          Payment[]
}

model CustomerIdentity {
  id                  String   @id @default(uuid())
  customerId          String
  provider            String
  externalSubjectHash String
  externalUsername    String?
  displayName         String?
  verificationMethod  String
  status              String   @default("active")
  sourceChannel       String?
  verifiedAt          DateTime @default(now())
  linkedAt            DateTime @default(now())
  lastSeenAt          DateTime @default(now())
  revokedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            Customer @relation(fields: [customerId], references: [id])

  @@unique([provider, externalSubjectHash])
}

model AuthSession {
  id              String   @id @default(uuid())
  subjectType     String
  customerId      String
  authMethod      String
  consumerType    String
  accessTokenHash String   @unique
  tokenType       String   @default("Bearer")
  correlationId   String?
  createdAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?

  customer        Customer @relation(fields: [customerId], references: [id])
}

model IdempotencyRecord {
  id              String   @id @default(uuid())
  scope           String
  key             String
  actorContext    Json?
  semanticHash    String
  status          String
  resultReference String?
  correlationId   String?
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  expiresAt       DateTime?

  @@unique([scope, key])
}

model AuditEvent {
  id            String   @id @default(uuid())
  eventType     String
  subjectType   String?
  subjectId     String?
  targetType    String?
  targetId      String?
  action        String
  decision      String
  reasonCode    String?
  authMethod    String?
  sourceChannel String?
  correlationId String?
  metadata      Json?
  occurredAt    DateTime @default(now())
}

model DocumentVersion {
  id            String   @id @default(uuid())
  documentType  String
  version       String
  title         String
  filePath      String
  effectiveFrom DateTime
  createdAt     DateTime @default(now())

  consents      CustomerConsent[]
}

model CustomerConsent {
  id             String   @id @default(uuid())
  customerId     String
  documentId     String
  consentType    String
  isGranted      Boolean  @default(true)
  grantedAt      DateTime @default(now())
  revokedAt      DateTime?
  source         String
  ipAddress      String?

  customer       Customer @relation(fields: [customerId], references: [id])
  document       DocumentVersion @relation(fields: [documentId], references: [id])
}

model ClubAccount {
  id                 String   @id @default(uuid())
  customerId         String   @unique
  status             String   @default("active")
  currency           String   @default("RUB")
  balanceRub         Float    @default(0)
  availableBalanceRub Float   @default(0)
  reservedBalanceRub Float    @default(0)
  clubActive         Boolean  @default(false)
  activatedAt        DateTime?
  lastTopupAt        DateTime?
  lastTransactionId  String?
  projectionVersion  Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer           Customer @relation(fields: [customerId], references: [id])
  topups             ClubTopup[]
  transactions       ClubAccountTransaction[]
}

model ClubAccountTransaction {
  id                       String   @id @default(uuid())
  clubAccountId            String
  customerId               String
  transactionType          String
  direction                String
  amountRub                Float
  currency                 String   @default("RUB")
  availableDeltaRub        Float
  reservedDeltaRub         Float    @default(0)
  availableBalanceAfterRub Float
  reservedBalanceAfterRub  Float
  balanceAfterRub          Float
  status                   String   @default("posted")
  reason                   String
  referenceEntityType      String?
  referenceEntityId        String?
  sourceDomain             String?
  sourceId                 String?
  idempotencyKey           String?
  actorType                String   @default("customer")
  actorId                  String?
  correlationId            String?
  createdAt                DateTime @default(now())
  postedAt                 DateTime @default(now())

  clubAccount              ClubAccount @relation(fields: [clubAccountId], references: [id])

  @@unique([clubAccountId, idempotencyKey])
  @@index([customerId, postedAt])
  @@index([clubAccountId, postedAt])
}

model ClubTopup {
  id              String   @id @default(uuid())
  clubAccountId   String
  customerId      String
  amountRub       Float
  paymentProvider String
  paymentStatus   String   @default("pending")
  paymentId       String?
  channel         String
  createdAt       DateTime @default(now())
  paidAt          DateTime?

  clubAccount     ClubAccount @relation(fields: [clubAccountId], references: [id])
  payment         Payment?
}

model BonusAccount {
  id             String   @id @default(uuid())
  customerId     String   @unique
  balanceBonus   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer       Customer @relation(fields: [customerId], references: [id])
}

model BonusTransaction {
  id             String   @id @default(uuid())
  customerId     String
  orderId        String?
  referralId     String?
  type           String
  direction      String   @default("credit")
  amountBonus    Int
  source         String
  reason         String?
  referenceEntityType String?
  referenceEntityId   String?
  balanceAfterBonus   Int?
  comment        String?
  createdAt      DateTime @default(now())
  postedAt       DateTime @default(now())

  customer       Customer @relation(fields: [customerId], references: [id])
  order          Order?   @relation(fields: [orderId], references: [id])
  referral       Referral? @relation(fields: [referralId], references: [id])
}

model Machine {
  id             String   @id @default(uuid())
  name           String
  location       String?
  currentFlavor  String
  status         String   @default("online")
  cupsCapacity   Int      @default(160)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders         Order[]
  inventory      MachineInventory[]
}

model MachineInventory {
  id             String   @id @default(uuid())
  machineId      String
  itemType       String
  itemName       String
  capacity       Int?
  quantityLeft   Int?
  updatedAt      DateTime @updatedAt

  machine        Machine @relation(fields: [machineId], references: [id])
}

model Order {
  id                  String      @id @default(uuid())
  customerId           String
  status              OrderStatus @default(CREATED)
  amount              Float
  currency            String      @default("RUB")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  machineId            String?
  flavor               String?
  syrup                String?
  topping              String?
  basePriceRub         Float?
  clubDiscountRub      Float      @default(0)
  promoDiscountRub     Float      @default(0)
  bonusSpent           Int        @default(0)
  amountPaidRub        Float?
  bonusEarned          Int        @default(0)
  paymentMethod        String?
  paymentStatus        String     @default("pending")
  paidAt               DateTime?

  customer             Customer @relation(fields: [customerId], references: [id])
  machine              Machine? @relation(fields: [machineId], references: [id])
  bonusTransactions    BonusTransaction[]
  photoChallenge       PhotoChallenge?
  birthdayReward       BirthdayReward?

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model Referral {
  id                    String   @id @default(uuid())
  referrerCustomerId     String
  referredCustomerId     String?  @unique
  referralCode           String
  status                 String   @default("registered")
  firstPurchaseAt        DateTime?
  referrerBonusPaid      Boolean  @default(false)
  referredBonusPaid      Boolean  @default(false)
  milestoneBonusPaid     Boolean  @default(false)
  createdAt              DateTime @default(now())

  referrer               Customer @relation("Referrer", fields: [referrerCustomerId], references: [id])
  referred               Customer? @relation("Referred", fields: [referredCustomerId], references: [id])
  bonusTransactions      BonusTransaction[]
}

model PhotoChallenge {
  id             String   @id @default(uuid())
  customerId     String
  orderId        String   @unique
  photoFilePath  String?
  platform       String?
  postUrl        String?
  deadlineAt     DateTime
  status         String   @default("waiting")
  moderatorId    String?
  bonusAmount    Int      @default(30)
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())

  customer       Customer @relation(fields: [customerId], references: [id])
  order          Order    @relation(fields: [orderId], references: [id])
}

model BirthdayReward {
  id             String   @id @default(uuid())
  customerId     String
  year           Int
  status         String   @default("available")
  issuedAt       DateTime @default(now())
  expiresAt      DateTime
  redeemedAt     DateTime?
  orderId        String?  @unique

  customer       Customer @relation(fields: [customerId], references: [id])
  order          Order? @relation(fields: [orderId], references: [id])

  @@unique([customerId, year])
}

model Payment {
  id                String   @id @default(uuid())
  customerId        String?
  clubTopupId       String?  @unique

  amountRub         Float
  currency          String   @default("RUB")

  provider          String   @default("yookassa")
  providerPaymentId String?  @unique
  providerStatus    String?

  status            String   @default("pending")
  description       String?

  confirmationUrl   String?
  returnUrl         String?

  metadata          Json?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  confirmedAt       DateTime?
  canceledAt        DateTime?

  customer          Customer? @relation(fields: [customerId], references: [id])
  clubTopup         ClubTopup? @relation(fields: [clubTopupId], references: [id])
}
