NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# PostgreSQL is the MVP backend database.
# This value matches backend/docker-compose.yml defaults.
DATABASE_URL=postgresql://soft_ice_platform:soft_ice_platform@localhost:5432/soft_ice_platform?schema=public
DATABASE_SSL=false
DATABASE_CONNECTION_LIMIT=5

# Telegram Mini App authentication.
# Use a real bot token only in a secure runtime environment, never in source control.
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Local Docker Compose PostgreSQL settings.
POSTGRES_DB=soft_ice_platform
POSTGRES_USER=soft_ice_platform
POSTGRES_PASSWORD=soft_ice_platform
POSTGRES_PORT=5432
